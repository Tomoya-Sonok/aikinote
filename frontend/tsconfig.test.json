{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.integration.test.ts",
    "vitest.setup.ts",
    "mocks/**/*",
    "src/mocks/**/*",
    "src/test-utils/**/*"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
